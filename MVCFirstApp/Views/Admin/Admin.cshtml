@{
    ViewData["Title"] = "Admin";
}

<h1>Admin</h1>

<p class="text-muted">
    Manage users and system access
</p>

<hr />

<div class="mt-4" style="width:250px;">

    <div class="mb-2">
        <a asp-controller="User"
           asp-action="Create"
           class="btn btn-outline-dark w-100"
           style="border-radius:0;">
            👤 Manage Users
        </a>
    </div>

    <div class="mb-2">
        <a asp-controller="User"
           asp-action="Logout"
           class="btn btn-outline-danger w-100"
           style="border-radius:0;">
            🚪 Logout
        </a>
    </div>

</div>