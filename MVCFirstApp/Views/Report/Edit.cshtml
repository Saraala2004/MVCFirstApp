@model MVCFirstApp.Models.Report
@{
    Layout = "~/Views/Shared/_EmployeeLayout.cshtml";
}

<h2>Edit Report</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="ReportId" />

    <div class="mb-3">
        <label>Summary</label>
        <textarea asp-for="Summary" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label>Employee Opinion</label>
        <textarea asp-for="EmployeeOpinion" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">
        Save Changes
    </button>

</form>

