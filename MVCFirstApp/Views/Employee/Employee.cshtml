@{
    ViewData["Title"] = "Employee";
}

<h1>Employee</h1>

<div class="mt-4" style="width:250px;">

    <div class="mb-2">
        <a asp-controller="Employee" asp-action="MyTasks"
           class="btn btn-outline-dark w-100"
           style="border-radius:0;">
            📋 My Tasks
        </a>
    </div>

    <div class="mb-2">
        <a asp-controller="Employee" asp-action="UpdateStatus"
           class="btn btn-outline-dark w-100"
           style="border-radius:0;">
            🔄 Update Status
        </a>
    </div>

    <div class="mb-2">
        <a asp-controller="Employee" asp-action="SubmitReport"
           class="btn btn-outline-dark w-100"
           style="border-radius:0;">
            📝 Submit Report
        </a>
    </div>

    <div class="mb-2">
        <a asp-controller="User" asp-action="Login"
           class="btn btn-outline-danger w-100"
           style="border-radius:0;">
            🚪 Logout
        </a>
    </div>

</div>