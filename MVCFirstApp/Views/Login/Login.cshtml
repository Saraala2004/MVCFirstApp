@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login</title>

    <style>

            body {
                margin: 0;
                padding: 0;
                background-color: white;
                font-family: Arial;
            }

            
            .top-image img {
                width: 100%;
                max-height: 350px;
                object-fit: contain;
            }

            
            .title {
                text-align: center;
                margin-top: 20px;
                margin-bottom: 30px;
                font-size: 45px;
                font-weight: bold;
            }

           
            .login-form {
                width: 350px;
                margin: auto;
            }

                
                .login-form label {
                    display: block;
                    margin-bottom: 8px;
                    font-size: 22px;
                }

               
                .login-form input {
                    width: 100%;
                    height: 45px;
                    border: 1px solid black;
                    border-radius: 0px;
                    padding-left: 10px;
                    margin-bottom: 25px;
                    font-size: 16px;
                    background-color: white;
                }

            
            .login-btn {
                background-color: #0d6efd;
                color: white;
                border: none;
                border-radius: 0px;
                width: 90px;
                height: 40px;
                font-size: 16px;
                cursor: pointer;
            }

    </style>

</head>

<body>

    
    <div class="top-image">
        <img src="/images/logo.png" />
    </div>
   
    <div class="title">
        Login
    </div>

   
    <form method="post" action="/Login/CheckLogin" class="login-form">

        
        <label>📧 Email</label>

        <input type="email"
               name="Email"
               placeholder="Enter Email" />

       
        <label>🔒 Password</label>

        <input type="password"
               name="Password"
               placeholder="Enter Password" />

        
        <button type="submit" class="login-btn">
            Login
        </button>
        @if (ViewBag.Error != null)
        {
            <p style="color:red">
                @ViewBag.Error
            </p>
        }
    </form>

</body>
</html>