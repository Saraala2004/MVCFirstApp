<!DOCTYPE html>
<html lang="en">

<head>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - MVCFirstApp</title>

    <!-- Bootstrap -->

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Site CSS -->

    <link rel="stylesheet"
          href="~/css/site.css" />

    <style>

        body {
        background-color: #f3f4f6;
        margin: 0;
        overflow-x: hidden;
        }

        /* TOP NAVBAR */

        .top-navbar {
        background-color: #d1d5db;
        height: 70px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 25px;
        position: fixed; /* تعديل: يخلي الهيدر ثابت في مكانه فوق الشاشة ديماً */
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1050; /* تعديل: رقم عالي يضمن الهيدر يكون فوق الداشبورد ومش متغطي */
        }

        .project-title {
        font-size: 25px;
        font-weight: bold;
        color: black;
        }

        .nav-links a {
        text-decoration: none;
        color: black;
        margin-left: 25px;
        font-size: 20px;
        font-weight: 500;
        }

        /* SIDEBAR */

        .sidebar {
        position: fixed;
        top: 70px; /* تعديل: تبدأ من تحت الهيدر بـ 70 بكسل عشان ما تغطيش على كتيبة الهيدر */
        left: -260px;
        width: 260px;
        height: calc(100% - 70px); /* تعديل: تأخذ باقي طول الشاشة تحت الهيدر */
        background-color: #1f2937;
        transition: 0.3s ease;
        padding-top: 20px;
        z-index: 1000; /* تحت الهيدر وفوق محتوى الصفحة */
        }

        .sidebar.active {
        left: 0;
        }

        .sidebar a {
        display: block;
        color: white;
        text-decoration: none;
        padding: 18px 25px;
        font-size: 22px;
        }

        .sidebar a:hover {
        background-color: #374151;
        }

        /* MENU BUTTON */

        .menu-btn {
        font-size: 35px;
        cursor: pointer;
        margin-right: 20px;
        }

        /* CONTENT */

        .content {
        padding: 30px;
        margin-top: 70px; /* تعديل: مسافة أمان من فوق عشان الجدول ما يخش تحت الهيدر الثابت */
        margin-left: 0px; /* تعديل: يبدأ من الصفر ولما تفتح القائمة يندف بالـ JavaScript */
        transition: 0.3s ease;
        }

        /* تعديل إضافي: الحالة لما يندف المحتوى لليمين */
        .content.active {
        margin-left: 260px;
        }

    </style>

</head>
<body>

    <!-- NAVBAR -->

    <div class="top-navbar">

        <div class="d-flex align-items-center">

            <!-- MENU BUTTON -->

            <span class="menu-btn"
                  onclick="toggleSidebar()">

                ☰

            </span>

            <!-- PROJECT TITLE -->

            <span class="project-title">

                Electronic System for Managing Assignments and Reports

            </span>

        </div>

        <!-- RIGHT LINKS -->

        <div class="nav-links">

            <a href="#">Home</a>

            <a href="#">About</a>

            <a href="#">Help</a>

            <a href="#" onclick="logoutConfirm()">Logout</a>

        </div>

    </div>

    <!-- SIDEBAR -->

    <div class="sidebar"
         id="sidebar">

        <a href="/Employee/Dashboard">

            Dashboard

        </a>

       

        <a href="/Report/Create">

            Create Reports

        </a>

       

        <a href="/Report/Index">

            Reports List

        </a>

    </div>

    <!-- PAGE CONTENT -->

    <div class="content">

        @RenderBody()

    </div>

    <!-- JAVASCRIPT -->

    <script>

        function toggleSidebar() {
        // الكود الذكي والجديد: يضيف ويشيل الكلاس بس والـ CSS يتكفل بالباقي
        document.getElementById("sidebar").classList.toggle("active");
        document.querySelector(".content").classList.toggle("active");
        }
        function logoutConfirm() {
        let result = confirm("Are you sure you want to logout?");
        if (result) {
        window.location.href = "/Manager/Login";
        }
        }

    </script>
    <script>

        function confirmLogout(event) {
        event.preventDefault();

        Swal.fire({

        title: 'Logout?',

        text: 'Are you sure you want to logout?',

        icon: 'warning',

        showCancelButton: true,

        confirmButtonText: 'Yes, Logout',

        cancelButtonText: 'Cancel',

        confirmButtonColor: '#d33',

        cancelButtonColor: '#6c757d'

        }).then((result) => {

        if (result.isConfirmed) {

        window.location.href = "/Manager/Login";
        }

        });
        }

    </script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        function logoutConfirm() {

        Swal.fire({
        title: 'Logout?',
        text: 'Are you sure you want to logout?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Yes, Logout',
        cancelButtonText: 'Cancel'
        }).then((result) => {

        if (result.isConfirmed) {

        window.location.href = '/Login/Login';

        }

        });

        }
    </script>
</body>

</html>