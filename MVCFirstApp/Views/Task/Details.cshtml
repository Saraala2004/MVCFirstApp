@model MVCFirstApp.Models.TaskItem

@* 🗺️ إحاطة الصفحة بالكامل بحاوية بسيطة لتحديد العرض وجعلها في المنتصف *@
<div class="container mt-4" style="max-width: 700px;">

    <h2 class="mb-4" style="color: deepskyblue; font-weight: bold;">Task Details</h2>

    <div class="card p-4 shadow-sm border-0 bg-light">
        <form>
            <div class="mb-3">
                <label class="form-label text-secondary fw-bold">Title</label>
                <input value="@Model.Title" class="form-control bg-white" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label text-secondary fw-bold">Description</label>
                <textarea class="form-control bg-white" rows="4" readonly>@Model.Description</textarea>
            </div>

            <div class="mb-3">
                <label class="form-label text-secondary fw-bold">Target Entity</label>
                <input value="@Model.TargetEntity" class="form-control bg-white" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label text-secondary fw-bold">Due Date</label>
                <input value="@Model.DueDate.ToString("yyyy-MM-dd")" class="form-control bg-white" readonly />
            </div>

            <div class="mt-4">
                <a asp-action="MyTasks" class="btn btn-info text-white px-4">
                    Back to List
                </a>
            </div>
        </form>
    </div>
</div>